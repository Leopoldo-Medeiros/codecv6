APP_NAME=CodeCV6
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://codecv6.ddev.site

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=db
DB_USERNAME=db
DB_PASSWORD=db

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.ddev.site
SANCTUM_STATEFUL_DOMAINS=codecv6.ddev.site,codecv6.ddev.site:3000,192.168.1.39:3000,localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — use "log" in development (emails appear in storage/logs/laravel.log)
# Production: switch to "resend" (free tier 3k/month — get key at resend.com)
# or "smtp" with any provider. MAIL_FROM_ADDRESS must be a verified domain.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@codecv.ie"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (production) — uncomment and set MAIL_MAILER=resend
# RESEND_KEY=re_xxxxxxxxxxxx

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Nuxt frontend — used by `ddev nuxt` (loaded via --dotenv from root .env)
NUXT_PUBLIC_API_BASE=http://codecv6.ddev.site

# Search — set SCOUT_DRIVER=algolia and fill keys to enable full-text user search
# Use "null" (default) to disable without breaking the app
SCOUT_DRIVER=null
ALGOLIA_APP_ID=
ALGOLIA_SECRET=

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=http://codecv6.ddev.site:3000,http://192.168.1.39:3000,http://localhost:3000

# Canonical single frontend URL — used by backend redirects (OAuth callback, password reset).
# Pick ONE — must be the URL the user is actually browsing on.
APP_FRONTEND_URL=http://192.168.1.39:3000

# Sanctum token expiration in minutes (10080 = 7 days)
SANCTUM_TOKEN_EXPIRATION=10080

SCOUT_QUEUE=true

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://codecv6.ddev.site/api/auth/google/callback

# CV Analysis — Google Gemini (free tier: 1,500 req/day)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# AI features — Anthropic Claude (used for CV/LinkedIn analysis)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Stripe — payments (Checkout + webhooks)
# Get your keys at https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_, sk_test_) in development. The webhook secret is shown
# when you create the endpoint at https://dashboard.stripe.com/webhooks
# (or via `stripe listen --forward-to` for local testing).
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
