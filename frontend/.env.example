# Frontend env — loaded automatically by `npm run dev` (host mode).
# When running via `ddev nuxt` instead, the project-root .env is loaded
# via --dotenv ../.env and this file is ignored.
#
# Copy to frontend/.env to activate.

# Backend API base. Use HTTP locally to avoid the self-signed TLS cert
# the browser does not trust unless you ran `mkcert -install`.
NUXT_PUBLIC_API_BASE=http://codecv6.ddev.site

# Error monitoring — Sentry (browser). Leave empty to disable (no-op).
# Create a project at https://sentry.io and paste its DSN.
NUXT_PUBLIC_SENTRY_DSN=
